  "components": {
    "schemas": {
      "HTTPValidationError": {
        "properties": {
          "detail": {
            "items": {
              "$ref": "#/components/schemas/ValidationError"
            },
            "type": "array",
            "title": "Detail"
          }
        },
        "type": "object",
        "title": "HTTPValidationError"
      },
      "OptionsQuery": {
        "properties": {
          "budget": {
            "type": "number",
            "title": "Budget",
            "description": "購屋總預算 (萬元)",
            "example": 2500
          },
          "district": {
            "type": "string",
            "title": "District",
            "description": "行政區名稱",
            "example": "大安區"
          },
          "area": {
            "type": "number",
            "exclusiveMinimum": 0,
            "title": "Area",
            "description": "預期建物坪數 (坪)",
            "example": 25
          },
          "house_age": {
            "type": "number",
            "minimum": 0,
            "title": "House Age",
            "description": "偏好屋齡 (年)",
            "example": 15
          },
          "mrt_dist": {
            "type": "number",
            "title": "Mrt Dist",
            "description": "可接受距離捷運站公尺數",
            "example": 500
          },
          "lat": {
            "type": "number",
            "title": "Lat",
            "description": "中心點緯度 (地圖連動用)",
            "default": 25.04,
            "example": 25.0263
          },
          "lon": {
            "type": "number",
            "title": "Lon",
            "description": "中心點經度 (地圖連動用)",
            "default": 121.53,
            "example": 121.5283
          }
        },
        "type": "object",
        "required": [
          "budget",
          "district",
          "area",
          "house_age",
          "mrt_dist"
        ],
        "title": "OptionsQuery"
      },
      "PredictReq": {
        "properties": {
          "district": {
            "type": "string",
            "title": "District",
            "description": "行政區名稱",
            "example": "中正區"
          },
          "mrt_station": {
            "type": "string",
            "title": "Mrt Station",
            "description": "最近捷運站名稱",
            "example": "台北車站"
          },
          "building_area": {
            "type": "number",
            "exclusiveMinimum": 0,
            "title": "Building Area",
            "description": "建物總坪數 (坪)",
            "example": 25.5
          },
          "latitude": {
            "type": "number",
            "title": "Latitude",
            "description": "地理緯度",
            "example": 25.0348
          },
          "longitude": {
            "type": "number",
            "title": "Longitude",
            "description": "地理經度",
            "example": 121.5291
          },
          "house_type": {
            "type": "string",
            "enum": [
              "公寓",
              "大樓",
              "華廈",
              "透天",
              "套房"
            ],
            "title": "House Type",
            "description": "房屋類型",
            "default": "大樓",
            "example": "大樓"
          },
          "house_age": {
            "type": "number",
            "minimum": 0,
            "title": "House Age",
            "description": "屋齡 (年)",
            "default": 0,
            "example": 15
          },
          "total_floors": {
            "type": "integer",
            "exclusiveMinimum": 0,
            "title": "Total Floors",
            "description": "建物總層數",
            "default": 12,
            "example": 12
          },
          "start_floor": {
            "type": "integer",
            "title": "Start Floor",
            "description": "欲查詢樓層",
            "default": 5,
            "example": 5
          },
          "rooms": {
            "type": "integer",
            "title": "Rooms",
            "description": "房間數",
            "default": 2,
            "example": 2
          },
          "halls": {
            "type": "integer",
            "title": "Halls",
            "description": "廳數",
            "default": 1,
            "example": 1
          },
          "bathrooms": {
            "type": "integer",
            "title": "Bathrooms",
            "description": "衛浴數",
            "default": 1,
            "example": 1
          },
          "distance_to_mrt": {
            "type": "number",
            "title": "Distance To Mrt",
            "description": "距離捷運站公尺數",
            "default": 500,
            "example": 300
          }
        },
        "type": "object",
        "required": [
          "district",
          "mrt_station",
          "building_area",
          "latitude",
          "longitude"
        ],
        "title": "PredictReq"
      },
      "ValidationError": {
        "properties": {
          "loc": {
            "items": {
              "anyOf": [
                {
                  "type": "string"
                },
                {
                  "type": "integer"
                }
              ]
            },
            "type": "array",
            "title": "Location"
          },
          "msg": {
            "type": "string",
            "title": "Message"
          },
          "type": {
            "type": "string",
            "title": "Error Type"
          },
          "input": {
            "title": "Input"
          },
          "ctx": {
            "type": "object",
            "title": "Context"
          }
        },
        "type": "object",
        "required": [
          "loc",
          "msg",
          "type"
        ],
        "title": "ValidationError"
      }
    }
  },
  "tags": [
    {
      "name": "AI 精準預估",
      "description": "包含房價分位數回歸模型 (P10, P50, P90)，提供市場成交價格區間預測。"
    },
    {
      "name": "預算推薦",
      "description": "基於地理空間分析與使用者財務預算，提供個人化的置產組合建議。"
    },
    {
      "name": "市場趨勢分析",
      "description": "整合實價登錄大數據，呈現台北市各區房價成長率與市場健康指標。"
    },
    {
      "name": "頁面導覽",
      "description": "提供前端 HTML 頁面的渲染入口。"
    }
  ]
}